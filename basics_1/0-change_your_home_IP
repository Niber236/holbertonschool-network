#!/usr/bin/env bash
# Configures local host resolution inside /etc/hosts without breaking on busy mounts

# 1. Modifier localhost et facebook.com proprement via un fichier temporaire local
cat /etc/hosts | sed 's/127.0.0.1\s*localhost/127.0.0.2 localhost/g' > hosts.tmp

if grep -q "facebook.com" hosts.tmp; then
    sed -i 's/.*facebook.com/8.8.8.8 facebook.com/g' hosts.tmp
else
    echo "8.8.8.8 facebook.com" >> hosts.tmp
fi

# 2. Écraser le contenu de /etc/hosts par redirection (le flux passe outre le verrou du mount)
cat hosts.tmp > /etc/hosts
rm -f hosts.tmp
